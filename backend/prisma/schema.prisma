generator client {
  provider               = "prisma-client"
  output                 = "../src/generated/prisma"
  moduleFormat           = "cjs"
  generatedFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  owner
  staff
  accountant
}

enum ItemType {
  product
  service
  membership
  subscription
}

enum InvoiceStatus {
  draft
  pending
  paid
  overdue
}

enum PaymentMethod {
  cash
  upi
  card
  online
  razorpay
}

enum BillingCycle {
  monthly
  quarterly
  annual
}

enum SubscriptionStatus {
  active
  paused
  cancelled
}

enum ReminderStatus {
  pending
  sent
  failed
}

enum ReminderChannel {
  whatsapp
  email
  sms
}

enum PlanType {
  basic
  growth
  pro
}

model BusinessTemplate {
  id              String   @id @default(cuid())
  slug            String   @unique
  displayName     String   @map("display_name")
  defaultCurrency String   @default("INR") @map("default_currency")
  featuresEnabled Json     @map("features_enabled")
  reminderConfig  Json     @map("reminder_config")
  createdAt       DateTime @default(now()) @map("created_at")
  templateItems   TemplateItem[]
  businesses      Business[]
  @@map("business_templates")
}

model TemplateItem {
  id           String   @id @default(cuid())
  templateId   String   @map("template_id")
  name         String?
  type         String   @default("service")
  defaultPrice Decimal? @map("default_price") @db.Decimal(10, 2)
  category     String?
  template     BusinessTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  @@index([templateId])
  @@map("template_items")
}

model Business {
  id                 String    @id @default(cuid())
  name               String
  logo               String?
  address            String?
  currency           String    @default("INR")
  gstin              String?
  templateId         String?   @map("template_id")
  featuresEnabled    Json      @default("{}") @map("features_enabled")
  settingsOverride   Json      @default("{}") @map("settings_override")
  reminderConfig     Json      @default("{}") @map("reminder_config")
  plan               PlanType  @default(basic)
  planExpiresAt      DateTime? @map("plan_expires_at")
  whatsappMsgsUsed   Int       @default(0) @map("whatsapp_msgs_used")
  invoicesThisMonth  Int       @default(0) @map("invoices_this_month")
  onboardingComplete Boolean   @default(false) @map("onboarding_complete")
  createdAt          DateTime  @default(now()) @map("created_at")
  template               BusinessTemplate?      @relation(fields: [templateId], references: [id])
  users                  User[]
  customers              Customer[]
  items                  Item[]
  invoices               Invoice[]
  subscriptions          Subscription[]
  razorpayPlans          RazorpayPlan[]
  razorpaySubscriptions  RazorpaySubscription[]
  @@map("businesses")
}

model User {
  id           String   @id @default(cuid())
  businessId   String   @map("business_id")
  name         String
  email        String
  passwordHash String   @map("password_hash")
  role         UserRole @default(staff)
  createdAt    DateTime @default(now()) @map("created_at")
  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  @@unique([email, businessId])
  @@index([businessId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("refresh_tokens")
}

model Customer {
  id         String   @id @default(cuid())
  businessId String   @map("business_id")
  name       String
  phone      String?
  email      String?
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  business              Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoices              Invoice[]
  subscriptions         Subscription[]
  reminderLogs          ReminderLog[]
  razorpaySubscriptions RazorpaySubscription[]
  @@index([businessId])
  @@map("customers")
}

model Item {
  id           String   @id @default(cuid())
  businessId   String   @map("business_id")
  name         String
  type         ItemType @default(service)
  price        Decimal  @db.Decimal(10, 2)
  taxRate      Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 2)
  category     String?
  customFields Json     @default("{}") @map("custom_fields")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  business              Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoiceItems          InvoiceItem[]
  subscriptions         Subscription[]
  razorpayPlans         RazorpayPlan[]
  razorpaySubscriptions RazorpaySubscription[]
  @@index([businessId])
  @@map("items")
}

model Invoice {
  id            String        @id @default(cuid())
  businessId    String        @map("business_id")
  customerId    String        @map("customer_id")
  invoiceNumber String        @map("invoice_number")
  status        InvoiceStatus @default(pending)
  subtotal      Decimal       @db.Decimal(10, 2)
  taxAmount     Decimal       @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount   Decimal       @map("total_amount") @db.Decimal(10, 2)
  dueDate       DateTime      @map("due_date")
  pdfUrl        String?       @map("pdf_url")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer     Customer      @relation(fields: [customerId], references: [id])
  invoiceItems InvoiceItem[]
  payments     Payment[]
  reminders    Reminder[]
  reminderLogs ReminderLog[]
  @@unique([businessId, invoiceNumber])
  @@index([businessId])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String  @map("invoice_id")
  itemId    String? @map("item_id")
  name      String
  quantity  Int     @default(1)
  price     Decimal @db.Decimal(10, 2)
  taxRate   Decimal @default(0) @map("tax_rate") @db.Decimal(5, 2)
  total     Decimal @db.Decimal(10, 2)
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item      Item?   @relation(fields: [itemId], references: [id])
  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id        String        @id @default(cuid())
  invoiceId String        @map("invoice_id")
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod @default(cash)
  paidAt    DateTime      @default(now()) @map("paid_at")
  notes     String?
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  @@index([invoiceId])
  @@map("payments")
}

model Subscription {
  id            String             @id @default(cuid())
  businessId    String             @map("business_id")
  customerId    String             @map("customer_id")
  itemId        String             @map("item_id")
  billingCycle  BillingCycle       @map("billing_cycle")
  startDate     DateTime           @map("start_date")
  endDate       DateTime?          @map("end_date")
  status        SubscriptionStatus @default(active)
  lastBilledAt  DateTime?          @map("last_billed_at")
  nextBillingAt DateTime?          @map("next_billing_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])
  item     Item     @relation(fields: [itemId], references: [id])
  @@index([businessId])
  @@index([status])
  @@index([nextBillingAt])
  @@map("subscriptions")
}

model RazorpayPlan {
  id             String   @id @default(cuid())
  businessId     String   @map("business_id")
  itemId         String   @map("item_id")
  razorpayPlanId String   @unique @map("razorpay_plan_id")
  name           String
  period         String
  interval       Int      @default(1)
  amount         Decimal  @db.Decimal(10, 2)
  currency       String   @default("INR")
  createdAt      DateTime @default(now()) @map("created_at")
  business      Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  item          Item                   @relation(fields: [itemId], references: [id])
  subscriptions RazorpaySubscription[]
  @@index([businessId])
  @@index([itemId])
  @@map("razorpay_plans")
}

model RazorpaySubscription {
  id                     String    @id @default(cuid())
  businessId             String    @map("business_id")
  customerId             String    @map("customer_id")
  itemId                 String    @map("item_id")
  razorpayPlanId         String    @map("razorpay_plan_id")
  razorpaySubscriptionId String    @unique @map("razorpay_subscription_id")
  status                 String    @default("created")
  totalCount             Int       @map("total_count")
  paidCount              Int       @default(0) @map("paid_count")
  shortUrl               String?   @map("short_url")
  chargeAt               DateTime? @map("charge_at")
  currentStart           DateTime? @map("current_start")
  currentEnd             DateTime? @map("current_end")
  startAt                DateTime? @map("start_at")
  notesJson              String    @default("{}") @map("notes_json")
  createdAt              DateTime  @default(now()) @map("created_at")
  business Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer         @relation(fields: [customerId], references: [id])
  item     Item             @relation(fields: [itemId], references: [id])
  plan     RazorpayPlan     @relation(fields: [razorpayPlanId], references: [razorpayPlanId])
  payments RazorpayPayment[]
  @@index([businessId])
  @@index([customerId])
  @@index([status])
  @@map("razorpay_subscriptions")
}

model RazorpayPayment {
  id                     String   @id @default(cuid())
  businessId             String   @map("business_id")
  razorpaySubscriptionId String   @map("razorpay_subscription_id")
  razorpayPaymentId      String   @unique @map("razorpay_payment_id")
  amount                 Decimal  @db.Decimal(10, 2)
  currency               String   @default("INR")
  status                 String
  invoiceId              String?  @map("invoice_id")
  paidAt                 DateTime @map("paid_at")
  createdAt              DateTime @default(now()) @map("created_at")
  subscription RazorpaySubscription @relation(fields: [razorpaySubscriptionId], references: [razorpaySubscriptionId])
  @@index([razorpaySubscriptionId])
  @@index([businessId])
  @@map("razorpay_payments")
}

model Reminder {
  id          String          @id @default(cuid())
  invoiceId   String          @map("invoice_id")
  type        String
  scheduledAt DateTime        @map("scheduled_at")
  sentAt      DateTime?       @map("sent_at")
  status      ReminderStatus  @default(pending)
  channel     ReminderChannel @default(whatsapp)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  @@index([invoiceId])
  @@index([status])
  @@index([scheduledAt])
  @@map("reminders")
}

model ReminderLog {
  id         String          @id @default(cuid())
  invoiceId  String          @map("invoice_id")
  customerId String          @map("customer_id")
  type       String
  channel    ReminderChannel
  sentAt     DateTime        @default(now()) @map("sent_at")
  response   Json            @default("{}")
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id])
  @@index([invoiceId])
  @@index([customerId])
  @@map("reminder_logs")
}
