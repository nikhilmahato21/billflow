# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://billflow:billflow_secret@localhost:5432/billflow
POSTGRES_USER=billflow
POSTGRES_PASSWORD=billflow_secret
POSTGRES_DB=billflow

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT (min 32 chars each) ────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string-32-chars

# ─── WhatsApp (Meta Cloud API) ──────────────────────────────────────────────
WA_PHONE_ID=your-whatsapp-phone-number-id
WA_TOKEN=your-whatsapp-access-token
WA_WEBHOOK_SECRET=your-whatsapp-webhook-verify-token

# ─── Razorpay ───────────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Webhook secret from: https://dashboard.razorpay.com/app/webhooks
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ─── Email ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@yourdomain.com

# ─── Puppeteer (PDF) ────────────────────────────────────────────────────────
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── Frontend ───────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000/api
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
